# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 100

[*.html]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2
